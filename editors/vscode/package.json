{
  "name": "hale-lang",
  "displayName": "hale",
  "description": "Syntax highlighting and language server (live diagnostics, completion, hover) for the hale API-consumption language.",
  "version": "0.1.0",
  "publisher": "gabriel-lima",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/Tech-GabrielLima/hale.git" },
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages", "Linters"],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "hale",
        "aliases": ["hale", "hale"],
        "extensions": [".hale"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hale",
        "scopeName": "source.hale",
        "path": "./syntaxes/hale.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "hale",
      "properties": {
        "hale.serverPath": {
          "type": "string",
          "default": "hale",
          "description": "Path to the `hale` binary used to launch the language server (`hale lsp`)."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
